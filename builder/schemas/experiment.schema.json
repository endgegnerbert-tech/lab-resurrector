{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://labresurrector.dev/schemas/experiment.schema.json",
  "title": "Experiment Contract Schema",
  "description": "Validates experiment manifests for LabResurrector spaces. Every experiment must declare its identity, engine, parameters, measurements, and formulas.",
  "type": "object",
  "required": [
    "schemaVersion",
    "id",
    "title",
    "domain",
    "engine",
    "concepts",
    "parameters",
    "measurements",
    "formulas"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "minimum": 1,
      "description": "Version of the experiment contract schema this manifest targets."
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$",
      "description": "Unique, kebab-case identifier for the experiment space."
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title shown in the UI."
    },
    "domain": {
      "type": "string",
      "enum": ["physics"],
      "description": "Scientific domain. Currently only physics is supported."
    },
    "engine": {
      "type": "string",
      "enum": ["matter-js", "p5.js", "canvas-2d"],
      "description": "Rendering and physics engine used by this experiment."
    },
    "level": {
      "type": "string",
      "enum": ["school", "advanced", "research"],
      "description": "Target educational level (optional, defaults to 'school')."
    },
    "concepts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "description": "List of physics concepts covered by this experiment."
    },
    "parameters": {
      "type": "object",
      "minProperties": 1,
      "description": "Adjustable parameters of the experiment.",
      "additionalProperties": {
        "type": "object",
        "required": ["label", "min", "max", "step", "default", "unit"],
        "properties": {
          "label": {
            "type": "string",
            "description": "Display label for the parameter."
          },
          "min": {
            "type": "number",
            "description": "Minimum allowed value."
          },
          "max": {
            "type": "number",
            "description": "Maximum allowed value."
          },
          "step": {
            "type": "number",
            "exclusiveMinimum": 0,
            "description": "Step size for sliders/increments."
          },
          "default": {
            "type": "number",
            "description": "Default value when the experiment loads."
          },
          "unit": {
            "type": "string",
            "description": "Physical unit of the parameter (e.g., 'kg', 'm', 's')."
          },
          "meaning": {
            "type": "string",
            "description": "Didactic explanation of what this parameter affects."
          }
        },
        "additionalProperties": false
      }
    },
    "measurements": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "label", "unit"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-zA-Z0-9_]*$",
            "description": "Programmatic key used by ExperimentAPI.emitMeasurement()."
          },
          "label": {
            "type": "string",
            "description": "Display label shown in the live-values panel."
          },
          "unit": {
            "type": "string",
            "description": "Physical unit (e.g., 's', 'm/s', 'J')."
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    },
    "formulas": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "formula", "variables"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z][a-z0-9-]*$",
            "description": "Unique identifier for the formula within this experiment."
          },
          "name": {
            "type": "string",
            "description": "Human-readable name (e.g., 'Pendelperiode')."
          },
          "formula": {
            "type": "string",
            "description": "Formula string using LaTeX-style notation (e.g., 'T = 2π√(L/g)')."
          },
          "variables": {
            "type": "object",
            "minProperties": 1,
            "description": "Map of variable symbols to their descriptions.",
            "additionalProperties": {
              "type": "string",
              "description": "Description of the variable."
            }
          },
          "validWhen": {
            "type": "string",
            "description": "Conditions under which the formula applies (e.g., 'Kleine Auslenkung, masseloser Faden')."
          },
          "exampleCalculation": {
            "type": "string",
            "description": "Example calculation with actual numbers, shown in the Rechnung panel."
          }
        },
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
