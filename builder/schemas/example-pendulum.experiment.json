{
  "schemaVersion": 1,
  "id": "example-pendulum",
  "title": "Pendelperiode untersuchen",
  "domain": "physics",
  "engine": "matter-js",
  "level": "school",
  "concepts": ["Pendel", "Periodendauer", "Gravitation", "Harmonische Schwingung"],
  "parameters": {
    "mass": {
      "label": "Masse",
      "min": 1,
      "max": 10,
      "step": 0.5,
      "default": 2,
      "unit": "kg",
      "meaning": "Größere Masse erhöht die Trägheit, aber die Periodendauer bleibt gleich."
    },
    "length": {
      "label": "Länge",
      "min": 0.5,
      "max": 5,
      "step": 0.1,
      "default": 2,
      "unit": "m",
      "meaning": "Längere Pendel schwingen langsamer."
    },
    "gravity": {
      "label": "Gravitation",
      "min": 1,
      "max": 20,
      "step": 0.1,
      "default": 9.81,
      "unit": "m/s²",
      "meaning": "Stärkere Gravitation verkürzt die Periodendauer."
    },
    "amplitude": {
      "label": "Auslenkung",
      "min": 5,
      "max": 45,
      "step": 1,
      "default": 15,
      "unit": "°",
      "meaning": "Die Formel gilt nur für kleine Auslenkungen (< 15°)."
    }
  },
  "measurements": [
    { "id": "period", "label": "Periodendauer", "unit": "s" },
    { "id": "velocity", "label": "Maximale Geschwindigkeit", "unit": "m/s" },
    { "id": "energy", "label": "Gesamtenergie", "unit": "J" }
  ],
  "formulas": [
    {
      "id": "pendulum-period",
      "name": "Pendelperiode",
      "formula": "T = 2π √(L / g)",
      "variables": {
        "T": "Periodendauer (s)",
        "L": "Pendellänge (m)",
        "g": "Gravitationsbeschleunigung (m/s²)"
      },
      "validWhen": "Kleine Auslenkung (< 15°), masseloser Faden, keine Reibung, kein Luftwiderstand",
      "exampleCalculation": "L = 2.0 m, g = 9.81 m/s²\nT = 2π √(2.0 / 9.81)\nT ≈ 2.84 s"
    }
  ]
}
